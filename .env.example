# EmailJS configuration
# Create a free account at https://www.emailjs.com/
# 1. Create an Email Service (Gmail, Outlook, etc.) → copy the Service ID
# 2. Create an Email Template with variables: {{from_name}}, {{reply_to}}, {{message}} → copy the Template ID
# 3. Go to Account → API Keys → copy the Public Key
# Then add these three values as GitHub Actions secrets (Settings → Secrets and variables → Actions):
#   VITE_EMAILJS_SERVICE_ID
#   VITE_EMAILJS_TEMPLATE_ID
#   VITE_EMAILJS_PUBLIC_KEY

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Google Analytics – Measurement ID (format: G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=G-S36H1ZW6HS

# Google AdSense – Publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
VITE_ADSENSE_PUB_ID=ca-pub-5907579868808585

# Google Search Console – site verification code (only the code, not the full meta tag)
VITE_GOOGLE_SITE_VERIFICATION=google86a3028a8ce57f3d
